# PostgreSQL
DATABASE_URL=postgresql://estateos:estateos@localhost:30210/estateos
POSTGRES_PASSWORD=replace-me

# Better-Auth
BETTER_AUTH_SECRET=replace-with-32-byte-hex
BETTER_AUTH_URL=https://estateos.ru
NEXT_PUBLIC_AUTH_URL=https://estateos.ru

# SMTP (Beget)
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_USER=noreply@estateos.ru
SMTP_PASSWORD=replace-me
SMTP_FROM="EstateOS <noreply@estateos.ru>"

# Phase 2+ (TTS) — not used in Phase 0
TTS_PRIMARY=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_SUSANNA_VOICE_ID=
OPENAI_API_KEY=
OPENAI_TTS_VOICE=nova

# Phase 1+ (STT)
DEEPGRAM_API_KEY=

# Phase 1+ (LLM)
OPENROUTER_API_KEY=

# Phase 4+ (Telegram bot)
TELEGRAM_BOT_TOKEN=

# Proxy (ElevenLabs blocks RF)
HTTPS_PROXY_FOR_ELEVENLABS=http://127.0.0.1:10809

# === Phase 1 Ext (2026-05-18) — LLM model selection ===
# Default behavior (если ничего не задано) = moonshotai/kimi-k2 везде (backward compat)
# Recommended production: gemini-2.5-flash-lite для extract/summarize (95% accuracy RU, 6× faster vs kimi)
LLM_MODEL=google/gemini-2.5-flash-lite      # default для extract/summarize/command
LLM_MODEL_PARSE=google/gemini-2.5-flash     # parseEventCommand (нужнее качество для NLU дат)
LLM_MODEL_BRIEF=moonshotai/kimi-k2          # morning brief (kimi для выразительности narrative)
