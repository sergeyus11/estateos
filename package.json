{
  "name": "estateos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:migrate": "pnpm --filter @estateos/db migrate",
    "db:generate": "pnpm --filter @estateos/db generate",
    "db:studio": "pnpm --filter @estateos/db studio",
    "seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "nanoid": "5.0.9",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.18.0"
  }
}
